rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Purchase Order Validation
    function isValidOrder(data) {
      return data.keys().hasAll(['createdAt', 'exchangeRate', 'totalUSD', 'totalVES', 'status', 'clientName', 'items'])
        && data.exchangeRate is number
        && data.totalUSD is number
        && data.totalVES is number
        && data.status in ['draft', 'active', 'completed']
        && data.clientName is string;
    }

    // Item Validation
    function isValidItem(data) {
      return data.keys().hasAll(['garmentType', 'quantity', 'size', 'priceUSD', 'totalUSD'])
        && data.garmentType is string && data.garmentType.size() <= 100
        && data.quantity is number && data.quantity > 0
        && data.size is string
        && data.priceUSD is number && data.priceUSD >= 0
        && data.totalUSD is number && data.totalUSD >= 0;
    }

    match /orders/{orderId} {
      allow read, create, update, delete: if true;
    }

    match /orders/{orderId}/items/{itemId} {
      allow read, create, update, delete: if true;
    }
  }
}
